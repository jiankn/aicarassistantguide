---
import { disclaimer, navItems } from '../data/site';
---
<footer class="site-footer">
  <div class="container footer-join">
    <div>
      <p class="footer-join-title">Stay informed</p>
      <p>Rollout updates, setup checklists, and safer in-car assistant tips — no account needed.</p>
    </div>
    <a class="footer-cta" href="/update-tracker/">Follow updates</a>
    <a class="back-top" href="#">Back to top ↑</a>
  </div>
  <div class="container footer-grid">
    <section>
      <p class="footer-brand">
        <img src="/assets/logo-option-c.svg" alt="AI Car Assistant Guide logo" width="34" height="34" />
        <span>AI Car Assistant Guide</span>
      </p>
      <p>{disclaimer}</p>
    </section>
    <section>
      <h3>Guides</h3>
      <div class="footer-links">
        {navItems.slice(0, 4).map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </section>
    <section>
      <h3>Tools</h3>
      <div class="footer-links">
        <a href="/gemini-car-commands/">Gemini commands</a>
        <a href="/gemini-vs-google-assistant-in-cars/">Gemini vs Google Assistant</a>
        <a href="/chatgpt-carplay-prompts-for-driving/">CarPlay prompts</a>
        <a href="/update-tracker/">Update tracker</a>
        <a href="/google-built-in-vs-android-auto/">Platform comparison</a>
      </div>
    </section>
    <section>
      <h3>Trust</h3>
      <div class="footer-links">
        <a href="/about/">About</a>
        <a href="/methodology/">Methodology</a>
        <a href="/editorial-policy/">Editorial policy</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy-policy/">Privacy</a>
        <a href="/terms/">Terms</a>
      </div>
    </section>
  </div>
  <div class="container footer-bottom">
    <small>© {new Date().getFullYear()} AI Car Assistant Guide. Independent driver-first information.</small>
    <small>Free guides for real drivers. No accounts, no forum.</small>
  </div>
</footer>
