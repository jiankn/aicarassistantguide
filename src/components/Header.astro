---
import { navGroups } from '../data/site';
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="AI Car Assistant Guide home">
      <span class="brand-mark" aria-hidden="true">
        <img src="/assets/logo-option-c.svg" alt="" width="34" height="34" />
      </span>
      <span class="brand-text">
        <span class="brand-name">AI Car Assistant</span>
        <span class="brand-sub">Guide</span>
      </span>
    </a>
    <nav class="nav task-nav" aria-label="Primary navigation">
      {navGroups.map((group) => (
        <details class="nav-group">
          <summary>{group.label}</summary>
          <div class="nav-panel">
            <a class="nav-panel-title" href={group.href}>{group.label}</a>
            {group.links.map((link) => <a href={link.href}>{link.label}</a>)}
          </div>
        </details>
      ))}
    </nav>
    <div class="header-actions" aria-label="Quick links">
      <a href="/update-tracker/"><svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" fill="#f59e0b" stroke="#d97706" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.73 21a2 2 0 0 1-3.46 0" fill="none" stroke="#d97706" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Updates</a>
      <a href="/methodology/"><svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="#4ade80" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>How we verify</a>
    </div>
    <details class="mobile-nav">
      <summary aria-label="Open navigation menu">
        <span class="mobile-nav-icon" aria-hidden="true"></span>
        <span class="sr-only">Menu</span>
      </summary>
      <div class="mobile-menu">
        {navGroups.map((group) => (
          <section>
            <a class="mobile-menu-title" href={group.href}>{group.label}</a>
            {group.links.map((link) => <a href={link.href}>{link.label}</a>)}
          </section>
        ))}
      </div>
    </details>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  const navGroups = Array.from(document.querySelectorAll<HTMLDetailsElement>('.task-nav .nav-group'));

  navGroups.forEach((group) => {
    group.addEventListener('toggle', () => {
      if (!group.open) return;

      navGroups.forEach((otherGroup) => {
        if (otherGroup !== group) {
          otherGroup.open = false;
        }
      });
    });
  });

  document.addEventListener('click', (event) => {
    if (event.target instanceof Node && header?.contains(event.target)) return;
    navGroups.forEach((group) => {
      group.open = false;
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    navGroups.forEach((group) => {
      group.open = false;
    });
  });
</script>
