---
import '../styles/global.css';
import AutoAds from '../components/AutoAds.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  pathname?: string;
  image?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, pathname = Astro.url.pathname, image = '/assets/hero-cockpit-collage-real.jpg', ogType = 'website', structuredData = [] } = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || site.url;
const siteName = import.meta.env.PUBLIC_SITE_NAME || site.name;
const gsc = import.meta.env.PUBLIC_GSC_VERIFICATION;
const ga4 = import.meta.env.PUBLIC_GA4_ID;
const canonical = new URL(pathname, siteUrl).toString();
const absoluteImage = image.startsWith('http') ? image : new URL(image, siteUrl).toString();
const schemaItems = Array.isArray(structuredData) ? structuredData : [structuredData];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    {gsc && <meta name="google-site-verification" content={gsc} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <AutoAds />
    {ga4 && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>}
    {ga4 && <script is:inline set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4}');`} />}
    {schemaItems.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="site-shell">
      <Header />
      <main id="main-content" class="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
